{
  "name": "api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:unit": "bun test src/rag.test.ts src/api/createGetAuthenticatedUser.test.ts src/api/createDocumentIndexingService.test.ts",
    "test:integration": "bun test src/createApp.test.ts && bun test src/createApp.rag.integration.test.ts",
    "test:e2e": "bun test src/smoke.e2e.test.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.1.1",
    "@pinecone-database/pinecone": "^5.1.2",
    "elysia": "^1.1.26",
    "js-tiktoken": "^1.0.21",
    "openai": "^4.104.0"
  },
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "^5.6.3"
  }
}
